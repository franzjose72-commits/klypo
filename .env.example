# Copia este archivo a .env y rellena con tus claves reales
# En RunPod: configura estas variables en el panel de Environment Variables

# Groq — transcripción Whisper + Llama (detección de clips virales)
GROQ_API_KEY=

# HuggingFace — pyannote.audio para diarización de voz (módulo podcasts)
HF_TOKEN=

# OpenAI — fallback de transcripción (módulo podcasts)
OPENAI_API_KEY=

# AssemblyAI — transcripción con timestamps de palabras (módulo clips virales)
ASSEMBLYAI_API_KEY=

# Pexels — b-roll automático (módulo clips virales)
PEXELS_API_KEY=
